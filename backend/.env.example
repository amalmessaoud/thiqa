# ── App ────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-before-demo
DEBUG=True

# ── Database ────────────────────────────────────────────
DB_NAME=thiqa
DB_USER=thiqa_user
DB_PASSWORD=yourpassword
DB_HOST=localhost
DB_PORT=5432

# ── LLM — Groq (free at console.groq.com) ───────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxx

# ── Facebook Graph API (free at developers.facebook.com) ─
# Create an app, generate a Page Access Token
# Leave empty for now, add before building Feature 7
FACEBOOK_ACCESS_TOKEN=

# ── Cloudinary (free tier at cloudinary.com) ─────────────
# Sign up, go to Dashboard, copy the API Environment Variable
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ── CORS ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173